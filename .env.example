# ===========================================
# CreatorHub - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- AI Providers ---
GEMINI_API_KEY=AIza...your-gemini-key

# --- VietQR Bank Transfer ---
VIETQR_BANK_BIN=970436
VIETQR_ACCOUNT_NO=your_account_number
VIETQR_ACCOUNT_NAME=your_account_name

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Zernio (getlate.dev) — Social Media Publishing API ---
# Get from: https://zernio.com → Settings → API Keys
# Leave empty to use demo mode (fake publishing)
ZERNIO_API_KEY=sk_your_api_key_here
# Get from: Zernio Dashboard → Profiles → copy Profile ID
ZERNIO_PROFILE_ID=your_profile_id_here

# --- Feature Flags (build-time, NEXT_PUBLIC_*) ---
# Bật/tắt tính năng cho bản demo. Giá trị phải là chuỗi "true" mới bật;
# đổi xong phải build/deploy lại vì biến NEXT_PUBLIC_* được nhúng lúc build.
NEXT_PUBLIC_ENABLE_OAUTH=false          # Nút đăng nhập Google (OAuth)
NEXT_PUBLIC_ENABLE_MEDIA_UPLOAD=false   # Media Library / upload media
NEXT_PUBLIC_ENABLE_VIDEO_GEN=false      # Sinh video AI (Veo)
